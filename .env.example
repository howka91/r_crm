# ============================================
# r_crm — Environment Configuration Template
# Copy to `.env` and fill in values
# ============================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-production-use-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_TIME_ZONE=Asia/Tashkent
DJANGO_LANGUAGE_CODE=ru

# --- Database ---
POSTGRES_DB=rcrm
POSTGRES_USER=rcrm
POSTGRES_PASSWORD=rcrm_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT ---
JWT_ACCESS_LIFETIME_MINUTES=60
JWT_REFRESH_LIFETIME_DAYS=14

# --- SMS (Eskiz.uz) ---
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
ESKIZ_BASE_URL=https://notify.eskiz.uz/api

# --- LibreOffice (для docx→pdf конвертации) ---
LIBREOFFICE_HOST=libreoffice
LIBREOFFICE_PORT=2002

# --- Media / Files ---
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=r_crm

# --- Legacy DB (для миграции на Этапе 9) ---
LEGACY_POSTGRES_HOST=
LEGACY_POSTGRES_PORT=5432
LEGACY_POSTGRES_DB=
LEGACY_POSTGRES_USER=
LEGACY_POSTGRES_PASSWORD=
